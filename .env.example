PORT=3000
NODE_ENV=development

# Neon PostgreSQL — utiliser une chaîne de connexion régénérée depuis le dashboard Neon
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# JWT
JWT_SECRET=change_me_to_a_long_random_string_minimum_32_chars
JWT_EXPIRES_IN=7d

# Cloudinary — récupérer les clés sur https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
